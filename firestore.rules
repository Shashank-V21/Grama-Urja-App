rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }
    
    function isOperator() {
      return isSignedIn() && getUserData().role == 'operator';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Villages and Zones
    match /villages/{villageId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /zones/{zoneId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Power Status and History
    match /powerStatus/{zoneId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOperator();
    }
    match /statusHistory/{historyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOperator();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin() || isOperator();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Pumps
    match /pumpStatus/{zoneId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOperator();
    }
    match /pumpCommands/{commandId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isOperator();
    }
    match /pumpLogs/{logId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOperator();
    }
  }
}
